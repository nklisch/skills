# Python bytecode (e.g. from running hook script tests)
__pycache__/
*.pyc

# Node — plugin dependencies install locally (e.g. plugins/*/node_modules);
# lockfiles (bun.lock) ARE committed for reproducible installs.
node_modules/

# peeragent per-repo job store (local cross-model delegation cache)
.peeragent/

# .research/ raw source fetches — never travel; only derived material is committed.
# Scoped to .research/ (not global) so source PDFs elsewhere in the repo are unaffected.
.research/reference/**/raw/
.research/**/*.pdf
.research/**/*.epub
.research/**/*.azw3
.research/**/*.mobi

# deep-code-scan in-flight scanner packets; final summaries live in .work items.
.work/scan-artifacts/
