{
  "name": "nklisch-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Root Pi package manifest for the nklisch skills monorepo.",
  "author": {
    "name": "nklisch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nklisch/skills.git"
  },
  "license": "MIT",
  "scripts": {
    "check:pi-packages": "bash plugins/agile-workflow/scripts/tests/pi-package-metadata.test.sh",
    "publish:pi": "bash scripts/publish-pi-packages.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2"
  },
  "keywords": [
    "pi-package",
    "agent-skills",
    "agile-workflow",
    "ux-ui-design",
    "code-audit",
    "nates-toolkit",
    "agentic-research",
    "agent-coordination",
    "background-tasks",
    "zai-research"
  ],
  "pi": {
    "extensions": [
      "./plugins/agile-workflow/extensions/agile-workflow.ts",
      "./plugins/background-tasks/extensions/background-tasks.ts",
      "./plugins/zai-research/extensions/index.ts",
      "./plugins/nates-toolkit/extensions/nates-toolkit.ts"
    ],
    "skills": [
      "./plugins/agile-workflow/skills",
      "./plugins/ux-ui-design/skills",
      "./plugins/code-audit/skills",
      "./plugins/nates-toolkit/skills",
      "./plugins/agentic-research/skills",
      "./plugins/agent-coordination/skills",
      "./plugins/background-tasks/skills",
      "./plugins/zai-research/skills"
    ]
  }
}
